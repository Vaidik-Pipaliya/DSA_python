   "source": [
    "def armstrong(n): #321\n",
    "    num = n \n",
    "    total = 0\n",
    "    length = len(str(n))\n",
    "    while num > 0:\n",
    "        ld = num % 10\n",
    "        total = total+(ld ** length)\n",
    "        num = num // 10\n",
    "    return total == n\n",
    "\n",
    "armstrong(321)"
   ]
  }
 ],
