    "class solution(object):\n",
    "    def fib(self,n):\n",
    "        if n  == 0  or n ==1:\n",
    "            return n\n",
    "        return self.fib(n-1) + self.fib(n-2)\n",
    "obj = solution()\n",
    "print(obj.fib(10))"
   ]
  }
