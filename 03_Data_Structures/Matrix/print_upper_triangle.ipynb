   "source": [
    "nums = [[5,20,3],[7,10,9],[1,52,6]]\n",
    "row = len(nums)\n",
    "col = len(nums[0])\n",
    "for i in range(0,row):\n",
    "    for j in range(0,col):\n",
    "        if j>=i:\n",
    "            print(nums[i][j],end=\" \")\n",
    "        else:\n",
    "            print(\"*\", end=\" \")\n",
    "    print()\n",
    "\n"
   ]
  },
