   "source": [
    "def selection_sort(num):\n",
    "    n=len(num)\n",
    "    for i in range(0,num):\n",
    "        min_index = i\n",
    "        for j in range(i+1,n):\n",
    "            if num[j]<num[min_index]:\n",
    "                min_index = j\n",
    "        num[i],num[min_index] = num[min_index],num[i]"
   ]
  }
