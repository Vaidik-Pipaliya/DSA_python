    "nums = [3,5,6,8,9,10,20]\n",
    "def check(nums):\n",
    "    n = len(nums)\n",
    "    for i in range(0,n-1):\n",
    "        if nums[i]<nums[i+1]:\n",
    "            return True\n",
    "        else:\n",
    "            return False\n",
    "check(nums)\n"
   ]
