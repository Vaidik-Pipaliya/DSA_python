    "nums = [-2,1,-3,4,-1,2,1,-5,4]\n",
    "def maxs(nums):\n",
    "    n = len(nums)\n",
    "    maxi = float(\"-inf\")\n",
    "    total = 0\n",
    "    for i in range (0,n):\n",
    "        total = total + nums[i]\n",
    "        maxi = max(maxi,total)\n",
    "        if total < 0:\n",
    "            total = 0\n",
    "    return maxi\n",
    "maxs(nums)"
   ]
